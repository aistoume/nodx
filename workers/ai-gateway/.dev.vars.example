# Copy this file to `.dev.vars` and fill in real values for `wrangler dev`.
# `.dev.vars` is gitignored — never commit secrets.
#
# Production values are set via:
#   pnpm --filter @nodx/ai-gateway exec wrangler secret put ANTHROPIC_API_KEY
#   pnpm --filter @nodx/ai-gateway exec wrangler secret put CLIENT_TOKEN

# Anthropic key with access to claude-sonnet-4-6 + claude-haiku-4-5.
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# Shared secret between the desktop app and this worker. Generate with:
#   openssl rand -hex 32
# Then put the same value in apps/desktop/.env.local as VITE_AI_CLIENT_TOKEN.
CLIENT_TOKEN=REPLACE_ME_WITH_A_LONG_RANDOM_STRING
