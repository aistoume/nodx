{
  "name": "nodx",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.11.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "desktop": "pnpm --filter @nodx/desktop",
    "desktop:dev": "pnpm --filter @nodx/desktop tauri dev",
    "desktop:build": "pnpm --filter @nodx/desktop tauri build"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.2"
  }
}
