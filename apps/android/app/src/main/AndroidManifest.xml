<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <!-- 悬浮球先零授权就位（specialUse），投屏类型等首次截屏拿到授权后再升级 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- 收集库回读 Pictures/nodx（重装后失去 MediaStore 所有权时需要） -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Nodx">

        <activity
            android:name=".GalleryActivity"
            android:exported="false" />

        <activity
            android:name=".WheelSettingsActivity"
            android:exported="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ActionLogActivity"
            android:exported="false"
            android:label="@string/log_title" />

        <!-- 无障碍截屏服务（长效截屏）暂从 Play 版下线：Google 对「非无障碍
             工具却用 AccessibilityService」要求应用内 prominent disclosure 弹窗
             + 演示视频。首发先移除,MediaProjection 全功能可用（每会话一授权）;
             合规的告知弹窗做好后再随新版本恢复。CaptureAccessibilityService.kt /
             capture_accessibility.xml 代码保留但未在 manifest 声明 → 不激活。 -->

        <!-- 透明中转页：点悬浮球时才弹「分享屏幕」授权 -->
        <!-- taskAffinity="" + NEW_TASK：中转页开在独立空任务里，不会把
             MainActivity 连带拉到前台；finish 后前台回落到点悬浮球时的来源 app -->
        <activity
            android:name=".VoiceInputActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:theme="@style/Theme.Nodx.Translucent" />

        <activity
            android:name=".ProjectionConsentActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:launchMode="singleTask"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <!-- 文字入口:系统选字工具栏「Nodx Lens」(PROCESS_TEXT,任何 app 内选字都出现)
             + 分享菜单(SEND text/plain)+ 悬浮球文字模式(EXTRA_FROM_BUBBLE)。透明宿主。 -->
        <activity
            android:name=".ProcessTextActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:launchMode="singleTask"
            android:theme="@style/Theme.Nodx.Translucent">
            <!-- priority 提升在选字工具栏里的排位（queryIntentActivities 按
                 priority 降序;上限 1000）。短 label「nodx」也更易留在工具栏内
                 而非 ⋮ 溢出菜单。注意:One UI 等 OEM 仍有系统级排序 + 常用度加权,
                 无法保证「永远第一」,但这两项能明显提前。 -->
            <intent-filter android:priority="900">
                <action android:name="android.intent.action.PROCESS_TEXT" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!-- 拍照模式:透明桥接页 → 系统相机 → 照片交回 Service 弹框选 overlay -->
        <activity
            android:name=".CameraCaptureActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:launchMode="singleTask"
            android:theme="@style/Theme.Nodx.Translucent" />

        <!-- 相机输出用 FileProvider(拍照写临时文件,授权相机 app 写入) -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Foreground service that holds the MediaProjection + floating bubble -->
        <service
            android:name=".FloatingBubbleService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection|specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="floating bubble quick-capture entry point" />
        </service>
    </application>
</manifest>
