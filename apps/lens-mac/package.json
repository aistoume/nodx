{
  "name": "@nodx/lens-mac",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "nodx Lens for macOS — system-wide select-and-explain via global hotkey ⌥+E",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build --no-bundle && tauri build --bundles dmg",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist src-tauri/target .turbo"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-global-shortcut": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2",
    "@tauri-apps/plugin-store": "^2",
    "preact": "^10.24.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@preact/preset-vite": "^2.9.0",
    "@tailwindcss/vite": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0"
  }
}
