{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "nodx",
  "version": "0.5.0",
  "identifier": "app.nodx.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "nodx",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "popover",
        "title": "nodx — explain",
        "url": "popover.html",
        "width": 460,
        "height": 360,
        "minWidth": 360,
        "minHeight": 260,
        "decorations": true,
        "transparent": false,
        "shadow": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "visible": false,
        "focus": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/media/**",
          "$APPLOCALDATA/media/**",
          "$HOME/Library/Application Support/app.nodx.desktop/media/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["nodx"]
      }
    }
  }
}
