# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit secrets.

# AI gateway URL.
# Local dev: leave as-is and start the worker with
#   pnpm --filter @nodx/ai-gateway dev
# Production: replace with your wrangler-issued URL.
VITE_AI_GATEWAY_URL=http://localhost:8787

# Bearer token shared with the worker. Must match
# workers/ai-gateway/.dev.vars CLIENT_TOKEN exactly.
#
# Two ways to power nodx's AI — the desktop config above is the SAME for both;
# you just choose which gateway listens on :8787:
#
#   1. API-key mode (default):   pnpm start
#        Cloudflare worker (@nodx/ai-gateway) calls Anthropic with your
#        ANTHROPIC_API_KEY (in workers/ai-gateway/.dev.vars). CLIENT_TOKEN
#        must match the worker's. Embeddings / CBR available.
#
#   2. Claude Code / subscription mode:   pnpm start:cli
#        local @nodx/cli-gateway shells out to `claude -p`, using your
#        already-logged-in Claude Code session (subscription OR key). No API
#        key in nodx. The token below can be ANY non-empty value (the CLI
#        gateway ignores it — localhost only). Requires Claude Code installed
#        + logged in; slower (each call cold-starts `claude`); no embeddings.
VITE_AI_CLIENT_TOKEN=replace-me-with-the-same-value-as-worker
