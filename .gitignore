**/src-tauri/target/
**/src-tauri/gen/
apps/desktop/src-tauri/target/
apps/desktop/src-tauri/gen/

# Build artifacts (packaged installers)
*.dmg

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editors / OS
.DS_Store
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
Thumbs.db

# Env
.env
.env.local
.env.*.local

# Cloudflare Workers local dev secrets
.dev.vars
.wrangler/

# Coverage
coverage/

# Obsidian metadata
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# Local Claude Code config
.claude/

# Pitch deck build scripts — kept local, not on GitHub
pitch/
apps/extension/*.zip

# Internal docs — live in the private repo (aistoume/nodx-private); local
# files stay at these paths for tooling but are not published.
/PRD.md
/CLAUDE.md
/docs/

# Release binaries — distributed via GitHub Releases / the aicon-web repo,
# kept on disk for rsync deploys but never tracked here
apps/web/downloads/*.dmg
apps/web/downloads/*.apk
apps/extension/*.zip
apps/lens-mac/*.dmg

# Personal editor config
.obsidian/
